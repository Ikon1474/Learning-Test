<%- include("partials/header") %>

<section class="auth-wrapper">
  <div class="auth-card w-100">
    <p class="text-uppercase fw-bold text-secondary small mb-2">User Account</p>
    <h1 class="page-title h2 mb-3">Create your account</h1>
    <p class="helper-text mb-4">
      Register with a username and password to submit learner licence details and track the final image uploaded by admin.
    </p>

    <form action="/register" method="POST" class="row g-3">
      <div class="col-12">
        <label class="form-label fw-semibold" for="username">Username</label>
        <input
          class="form-control"
          type="text"
          id="username"
          name="username"
          placeholder="Enter username"
          value="<%= formData && formData.username ? formData.username : '' %>"
          required
        />
      </div>

      <div class="col-12">
        <label class="form-label fw-semibold" for="password">Password</label>
        <input
          class="form-control"
          type="password"
          id="password"
          name="password"
          placeholder="At least 6 characters"
          minlength="6"
          required
        />
      </div>

      <div class="col-12 d-grid">
        <button class="btn btn-primary btn-lg" type="submit">Register</button>
      </div>
    </form>

    <p class="helper-text mt-4 mb-0">
      Already have an account?
      <a href="/login" class="fw-bold">Login here</a>
    </p>
  </div>
</section>

<%- include("partials/footer") %>
