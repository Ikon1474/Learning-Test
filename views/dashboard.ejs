<%- include("partials/header") %>

<section class="hero-card mb-4">
  <div class="row g-4 align-items-center">
    <div class="col-lg-8">
      <p class="text-uppercase fw-bold text-secondary small mb-2">User Dashboard</p>
      <h1 class="page-title mb-3">Hello, <%= user.username %></h1>
      <p class="page-subtitle mb-4">
        Submit your application number, date of birth, and learner password. Your wallet balance must have enough money before you submit. Once admin passes your learner licence, the uploaded image will appear here.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <span class="metric-pill">Wallet Balance: Rs. <%= Number(user.walletBalance || 0).toFixed(2) %></span>
        <span class="metric-pill warning">Service Price: Rs. <%= Number(servicePrice).toFixed(2) %></span>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="panel-card h-100">
        <h2 class="section-title h4 mb-3">Need help?</h2>
        <p class="helper-text mb-3">
          Contact admin on Telegram to request wallet balance or get help with your learner licence submission.
        </p>
        <a class="btn btn-primary w-100" href="<%= telegramLink %>" target="_blank" rel="noreferrer">
          Contact <%= adminTelegram %>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="panel-card mb-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
      <h2 class="section-title mb-2">Submit Learner Details</h2>
      <p class="helper-text mb-0">
        Add your application number, date of birth, and learner password. Rs. <%= Number(servicePrice).toFixed(2) %> will be deducted from your wallet when you submit.
      </p>
    </div>

    <a class="btn btn-primary btn-lg" href="/dashboard/apply">Submit Details</a>
  </div>
</section>

<section class="panel-card table-card">
  <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
    <div>
      <h2 class="section-title mb-2">Your Applications</h2>
      <p class="helper-text mb-0">Passed applications will show the uploaded learner licence image here.</p>
    </div>
    <span class="metric-pill"><%= applications.length %> total submissions</span>
  </div>

  <% if (!applications.length) { %>
    <div class="empty-state">
      <h3 class="h5 mb-2">No submissions yet</h3>
      <p class="helper-text mb-0">
        When you submit your first learner licence application, it will appear here with status updates.
      </p>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Submitted</th>
            <th>Application Number</th>
            <th>Date Of Birth</th>
            <th>Learner Status</th>
            <th>Price</th>
            <th>Learner Password</th>
            <th>Learner Licence Image</th>
          </tr>
        </thead>
        <tbody>
          <% applications.forEach(function (application) { %>
            <tr>
              <td><%= application.formattedDate %></td>
              <td><code><%= application.applicationNumber %></code></td>
              <td><%= application.formattedDob %></td>
              <td>
                <span class="badge-soft <%= application.status %>">
                  <%= application.statusLabel %>
                </span>
              </td>
              <td>Rs. <%= Number(application.servicePrice || servicePrice).toFixed(2) %></td>
              <td><code><%= application.learnerPassword %></code></td>
              <td>
                <% if (application.status === "passed" && application.hasImage) { %>
                  <div class="d-flex flex-column gap-2">
                    <img
                      class="result-image"
                      src="/dashboard/applications/<%= application._id %>/image"
                      alt="Learner licence image"
                    />
                    <a class="btn btn-outline-secondary btn-sm" href="/dashboard/applications/<%= application._id %>/image" target="_blank" rel="noreferrer">
                      Open Full Image
                    </a>
                  </div>
                <% } else { %>
                  <span class="text-secondary"><%= application.statusLabel %></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
