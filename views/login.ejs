<%- include("partials/header") %>

<section class="auth-wrapper">
  <div class="auth-card w-100">
    <p class="text-uppercase fw-bold text-secondary small mb-2">Welcome Back</p>
    <h1 class="page-title h2 mb-3">Login to your account</h1>
    <p class="helper-text mb-4">
      Use your registered username and password to access your learner licence dashboard and check submission status.
    </p>

    <form action="/login" method="POST" class="row g-3">
      <div class="col-12">
        <label class="form-label fw-semibold" for="username">Username</label>
        <input
          class="form-control"
          type="text"
          id="username"
          name="username"
          placeholder="Enter username"
          value="<%= formData && formData.username ? formData.username : '' %>"
          required
        />
      </div>

      <div class="col-12">
        <label class="form-label fw-semibold" for="password">Password</label>
        <input
          class="form-control"
          type="password"
          id="password"
          name="password"
          placeholder="Enter password"
          required
        />
      </div>

      <div class="col-12 d-grid">
        <button class="btn btn-primary btn-lg" type="submit">Login</button>
      </div>
    </form>

    <p class="helper-text mt-4 mb-0">
      Need an account?
      <a href="/register" class="fw-bold">Register here</a>
    </p>
  </div>
</section>

<%- include("partials/footer") %>
